@inherits LayoutComponentBase
@inject ThemeService ThemeService
@inject IJSRuntime JS
@inject NavigationManager Navigation
@implements IDisposable

<div class="landing-page @(ThemeService.IsDarkMode ? "dark-theme" : "")" dir="rtl">
    <header class="landing-header">
        <div class="header-container">
            <div class="logo" @onclick='() => Navigation.NavigateTo("/")' style="cursor: pointer;">FlowtrixAI</div>
            <div class="header-actions">
                @if (!_hasToken)
                {
                    <button class="login-btn" @onclick="GoToLogin">تسجيل الدخول</button>
                }
                else
                {
                    <div class="user-badge-landing">
                        <div class="u-avatar-landing">@(_userName?.FirstOrDefault().ToString().ToUpper())</div>
                        <div class="user-info-text">
                            <span class="u-name">@_userName</span>
                            <span class="u-role-badge @(_userRole == "مسؤول النظام" ? "admin" : "engineer")">@_userRole</span>
                        </div>
                        <div class="separator-div"></div>
                        <div class="action-buttons-wrapper">
                            <button class="dashboard-btn" @onclick="GoToDashboard">
                                <i class="bi bi-grid-fill"></i> لوحة التحكم
                            </button>
                            <button class="logout-btn-landing-new" @onclick="HandleLogout">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z"/>
                                    <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z"/>
                                </svg>
                                <span>خروج</span>
                            </button>
                        </div>
                    </div>
                }
                <button class="theme-toggle" @onclick="ThemeService.ToggleThemeAsync" aria-label="Toggle Dark Mode">
                    @if (ThemeService.IsDarkMode)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z"/>
                        </svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06a.752.752 0 0 1 .876.218z"/>
                        </svg>
                    }
                </button>
                @if (_userRole == "مسؤول النظام")
                {
                    <div class="admin-badge-premium">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M1 1.81l7 .71 7-.71V8c0 3.12-2.14 5.86-5 6.78V16l-2-1-2 1v-1.22c-2.86-.92-5-3.66-5-6.78V1.81zM8 1.12L1 2v6c0 3.25 2.15 6.13 5.42 7.15L8 16l1.58-.85C12.85 14.13 15 11.25 15 8V2l-7-.88z"/>
                            <path d="M8 4a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5z"/>
                        </svg>
                        <span>ADMIN</span>
                    </div>
                }
            </div>
        </div>
    </header>
    <main>
        @Body
    </main>
</div>

@code {
    private bool _hasToken = false;
    private string _userName = "";
    private string _userRole = "";

    protected override void OnInitialized()
    {
        ThemeService.OnThemeChanged += StateHasChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            _hasToken = !string.IsNullOrEmpty(token);
            if (_hasToken)
            {
                try { ParseTokenInfo(token); } catch {}
            }
            StateHasChanged();
        }
    }

    private void ParseTokenInfo(string token)
    {
        var payload = token.Split('.')[1];
        var jsonBytes = ParseBase64WithoutPadding(payload);
        var keyValuePairs = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(jsonBytes);

        if (keyValuePairs != null)
        {
            if (keyValuePairs.TryGetValue("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name", out var name))
                _userName = name.ToString();
            else if (keyValuePairs.TryGetValue("unique_name", out var uname))
                _userName = uname.ToString();

            if (keyValuePairs.TryGetValue("http://schemas.microsoft.com/ws/2008/06/identity/claims/role", out var role))
            {
                var roleStr = role.ToString();
                _userRole = roleStr == "Admin" ? "مسؤول النظام" : "مهندس مشروع";
            }
        }
    }

    private byte[] ParseBase64WithoutPadding(string base64)
    {
        switch (base64.Length % 4)
        {
            case 2: base64 += "=="; break;
            case 3: base64 += "="; break;
        }
        return Convert.FromBase64String(base64);
    }

    private void GoToLogin() => Navigation.NavigateTo("/login");
    private void GoToDashboard() => Navigation.NavigateTo("/dashboard");

    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        Navigation.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= StateHasChanged;
    }
}

